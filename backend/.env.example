# Server
PORT=3001

# Supabase (from https://supabase.com/dashboard project Settings > API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key
# Service role key (bypasses RLS) — required for webhook subscription writes
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# PRO emulation: comma-separated emails treated as Pro (dev/testing only, e.g. your@email.com)
# PRO_EMULATE_EMAILS=

# GitHub OAuth (from https://github.com/settings/developers New OAuth App)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3001/github/oauth/callback

# Frontend URL for OAuth redirect after GitHub connect (optional, defaults to http://localhost:3000)
FRONTEND_URL=http://localhost:3000

# Stripe (Task 3.1+ — see docs/STRIPE_SETUP.md)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRO_PRICE_ID=price_...
# Webhook signing secret from `stripe listen --forward-to localhost:3001/billing/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...

# OpenAI (for AI code review agents)
OPENAI_API_KEY=sk-...
# Optional — defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
# TODO: Remove this flag once correct OpenAI API key is configured
# Set to 'true' to use mock responses instead of calling OpenAI API (for testing/demo purposes)
USE_MOCK_OPENAI_RESPONSES=false
